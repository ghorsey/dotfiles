format = "[$user]($style)"

[vagrant]
# disabled = true
symbol = "Ôì▒ " # apl functional symbol down caret tilde - U+2371
style = "bg:color_vagrant fg:color_foreground_light"
format = "[$symbol($version)]($style)"

[vcsh]
# disabled = true
symbol = "¾░│Å " # nf-md-source_repository
style = "bg:color_vcsh fg:color_foreground_light"
format = "[$symbol$repo]($style)"

[vlang]
# disabled = true
symbol = "¾▒æ╣ " # nf-md-cosine_wave
style = "bg:color_vlang fg:color_foreground_light"
format = "[$symbol($version)]($style)"

[zig]
# disabled = true
symbol = "¯Ü® " # nf-seti-zig
# symbol = '\[Z\] '
style = "bg:color_zig fg:color_foreground_light"
format = "[$symbol($version)]($style)"

[custom.root]
disabled = true
description = "Only display username, if sudo or different from standard user"
style = "bold bg:color_base_red_light fg:color_foreground_light"
command = "echo $USER"
when = '[[ -z "$SSH_CONNECTION" ]] && ([[ -n "$SUDO_USER" ]] || [[ "$USER" != "$LOGNAME" ]])'
shell = ["bash", "--noprofile", "--norc"]
format = "[$output]($style)"

[custom.ssh_user]
disabled = true
description = "Display username, if on a ssh session, but not in tmux"
style = "bg:color_username fg:color_foreground_light"
command = "echo $USER"
when = '([[ -n "$SSH_CONNECTION" ]] && [[ -z "$TMUX" ]]) && ([[ "$USER" != "root" ]] && [[ -z "$SUDO_USER" ]] && [[ "$USER" == "$LOGNAME" ]])'
shell = ["bash", "--noprofile", "--norc"]
format = "[$output]($style)"

[custom.ssh_root]
disabled = true
description = "Display username on a ssh session, if different from standard user"
style = "bold bg:color_base_red_light fg:color_foreground_light"
command = "echo $USER"
when = '[[ -n "$SSH_CONNECTION" ]] && ([[ "$USER" == "root" ]] || [[ -n "$SUDO_USER" ]] || [[ "$USER" != "$LOGNAME" ]])'
shell = ["bash", "--noprofile", "--norc"]
format = "[$output]($style)"

[custom.ssh_host]
disabled = true
description = "Display hostname if on a ssh session, but not inside a tmux session"
style = "bg:color_hostname fg:color_foreground_dark bold"
command = "uname -n"
when = '[[ -n "$SSH_CONNECTION" ]] && [[ -z "$TMUX" ]]'
shell = ["bash", "--noprofile", "--norc"]
format = "[$output]($style)"
